# 复制为 .env 后按需修改

# Claude VLM（用户语音提问时需要）
ANTHROPIC_API_KEY=

# ── NitroGen ─────────────────────────────────────────────────────
# 仅测前端闭环（默认）：模拟 NitroGen + mock VLM，无需 GPU / Anthropic
NITROGEN_MOCK=1
VLM_MOCK=1

# 实机服务时改为 0，并填写 API / ZMQ：
# NITROGEN_MOCK=0
# VLM_MOCK=0
# ANTHROPIC_API_KEY=sk-ant-...
# NITROGEN_SERVER=tcp://localhost:5555
